# ==========================================
# HumanityOS Backend Environment Variables
# ==========================================

# General Config
PROJECT_NAME="HumanityOS"
ENV=development # development, staging, production
DEBUG=true
PORT=8080

# Security (Generate a secure key with: openssl rand -hex 32)
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://humanity:humanity_password@localhost:5432/humanityos

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# ChromaDB Vector Database
CHROMADB_HOST=localhost
CHROMADB_PORT=8001

# Google AI (Gemini) Config
# Obtain API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Model Context Protocol (MCP) Config
# Configure connection to MCP servers
MCP_SERVER_URLS='["http://localhost:8000/mcp"]'

# CORS Config (JSON formatted list of origins)
BACKEND_CORS_ORIGINS='["http://localhost:3000", "https://humanityos.web.app", "https://humanityos.firebaseapp.com"]'

# Logging
LOG_LEVEL=INFO
STRUCTURED_LOGGING=false
